#!/usr/bin/env bun
// update — check upstream for a newer codebase-memory-mcp release and, if one
// exists, bump the adjacent package.nix to it. Lives beside the flake it maintains.
//
//   ./flakes/codebase-memory-mcp/update [--check] [--yes] [--pre]
//
//     (no flags)  check, report, then interactively prompt to apply the bump
//     --check     report only; never prompt or modify (good for CI/cron)
//     --yes, -y   apply the bump without prompting
//     --pre       also consider pre-release tags (vX.Y.Z-rc1, …)
//
// owner/repo/version/hash are read straight from package.nix (single source of
// truth). Tags come from the GitHub API (via `gh` if available, else fetch),
// are semver-compared, and on a bump the source SRI hash is re-prefetched with
// nix and written back in place. Does not build, stage, or commit.
import { $ } from "bun";
import { existsSync } from "node:fs";
import { join } from "node:path";
import { createInterface } from "node:readline/promises";

const args = process.argv.slice(2);
const CHECK_ONLY = args.includes("--check") || args.includes("--dry-run");
const ASSUME_YES = args.includes("--yes") || args.includes("-y");
const INCLUDE_PRE = args.includes("--pre");

// prettier-ignore
const c = { grn: "\x1b[32m", ylw: "\x1b[33m", red: "\x1b[31m", cyn: "\x1b[36m", b: "\x1b[1m", dim: "\x1b[2m", x: "\x1b[0m" };
const info = (m: string) => console.log(m);
const ok = (m: string) => console.log(`${c.grn}✓${c.x} ${m}`);
const warn = (m: string) => console.log(`${c.ylw}!${c.x} ${m}`);
const die = (m: string): never => {
  console.error(`${c.red}✗${c.x} ${m}`);
  process.exit(1);
};

// package.nix is this script's sibling — resolve it from the script's own dir so
// the updater works no matter the current working directory.
const PKG = join(import.meta.dir, "package.nix");
if (!existsSync(PKG)) die(`package.nix not found next to this script at ${PKG}`);
const nix = await Bun.file(PKG).text();

const field = (name: string) => nix.match(new RegExp(`\\b${name}\\s*=\\s*"([^"]+)"`))?.[1];
const owner = field("owner") ?? die("could not parse `owner` from package.nix");
const repo = field("repo") ?? die("could not parse `repo` from package.nix");
const current = field("version") ?? die("could not parse `version` from package.nix");
// package.nix builds `tag = "<prefix>${finalAttrs.version}"`; recover the prefix.
const tagPrefix = nix.match(/tag\s*=\s*"([^$"]*)\$\{finalAttrs\.version\}"/)?.[1] ?? "v";

type Tag = { name: string; version: string; pre: string | null };

async function fetchTagNames(): Promise<string[]> {
  if (Bun.which("gh")) {
    try {
      const out = await $`gh api repos/${owner}/${repo}/tags --paginate --jq ${".[].name"}`.text();
      return out.split("\n").map((s) => s.trim()).filter(Boolean);
    } catch {
      // gh missing auth / offline — fall through to an unauthenticated fetch
    }
  }
  const headers: Record<string, string> = {
    "User-Agent": "update-codebase-memory-mcp",
    Accept: "application/vnd.github+json",
  };
  const token = process.env.GITHUB_TOKEN || process.env.GH_TOKEN;
  if (token) headers.Authorization = `Bearer ${token}`;
  const res = await fetch(`https://api.github.com/repos/${owner}/${repo}/tags?per_page=100`, { headers });
  if (!res.ok) die(`GitHub API ${res.status} ${res.statusText} — set GITHUB_TOKEN if rate-limited`);
  return ((await res.json()) as { name: string }[]).map((t) => t.name);
}

function parseTag(name: string): Tag | null {
  const m = name.match(/^v?(\d+)\.(\d+)\.(\d+)(?:-(.+))?$/);
  return m ? { name, version: `${+m[1]}.${+m[2]}.${+m[3]}`, pre: m[4] ?? null } : null;
}

// compare dotted numeric versions: >0 if a>b
const cmp = (a: string, b: string) => {
  const pa = a.split(".").map(Number);
  const pb = b.split(".").map(Number);
  for (let i = 0; i < 3; i++) if (pa[i] !== pb[i]) return pa[i] - pb[i];
  return 0;
};

info(`${c.b}codebase-memory-mcp${c.x} ${c.dim}(${owner}/${repo})${c.x}`);
info(`  current: ${c.cyn}${current}${c.x}`);

const tags = (await fetchTagNames())
  .map(parseTag)
  .filter((t): t is Tag => !!t && (INCLUDE_PRE || !t.pre));
if (!tags.length) die("no semver tags found upstream");
// highest version first; for equal versions, a stable release outranks a pre-release
tags.sort((a, b) => cmp(b.version, a.version) || (a.pre ? 1 : -1));
const latest = tags[0];
info(`  latest:  ${c.cyn}${latest.version}${c.x}${latest.pre ? `${c.dim} (pre-release)${c.x}` : ""}`);

const delta = cmp(latest.version, current);
if (delta <= 0) {
  ok(delta === 0 ? "already up to date" : `local (${current}) is ahead of upstream latest (${latest.version})`);
  process.exit(0);
}

warn(`newer release available: ${current} → ${c.grn}${latest.version}${c.x}`);
if (CHECK_ONLY) {
  info(`${c.dim}run without --check to upgrade${c.x}`);
  process.exit(0);
}

let proceed = ASSUME_YES;
if (!proceed) {
  if (!process.stdin.isTTY) die("not a TTY; re-run with --yes to apply non-interactively");
  const rl = createInterface({ input: process.stdin, output: process.stdout });
  const ans = (await rl.question(`Upgrade package.nix to ${latest.version}? [y/N] `)).trim();
  rl.close();
  proceed = /^y(es)?$/i.test(ans);
}
if (!proceed) {
  info("aborted; package.nix unchanged");
  process.exit(0);
}

// package.nix fetches `${tagPrefix}${version}`; make sure that matches the real tag.
const wantTag = `${tagPrefix}${latest.version}`;
if (wantTag !== latest.name) {
  die(`package.nix fetches tag "${wantTag}" but the upstream tag is "${latest.name}" — fix the tag template first`);
}

const url = `https://github.com/${owner}/${repo}/archive/refs/tags/${wantTag}.tar.gz`;
info(`${c.dim}prefetching ${url}${c.x}`);
const base32 = (await $`nix-prefetch-url --unpack ${url}`.text())
  .split("\n")
  .map((s) => s.trim())
  .filter(Boolean)
  .pop();
if (!base32) die("nix-prefetch-url produced no hash");
let sri: string;
try {
  sri = (await $`nix hash to-sri --type sha256 ${base32}`.text()).trim();
} catch {
  sri = (await $`nix hash convert --hash-algo sha256 ${base32}`.text()).trim();
}
if (!sri.startsWith("sha256-")) die(`unexpected hash from nix: ${sri}`);

const oldHash = field("hash") ?? die("could not parse current `hash` from package.nix");
const updated = nix
  .replace(/(\bversion\s*=\s*")[^"]+(")/, `$1${latest.version}$2`)
  .replace(/(\bhash\s*=\s*")sha256-[^"]+(")/, `$1${sri}$2`);
if (updated === nix) die("nothing written — version/hash patterns did not match package.nix");
await Bun.write(PKG, updated);

ok(`bumped ${current} → ${latest.version}`);
info(`  ${c.dim}hash ${oldHash}${c.x}`);
info(`  ${c.dim}  -> ${sri}${c.x}`);
info("");
info(`${c.b}next${c.x} (from repo root):`);
info("  git add flakes/codebase-memory-mcp/package.nix");
info("  nix build .#packages.aarch64-darwin.codebase-memory-mcp");
info("  darwin-rebuild switch --flake .");
