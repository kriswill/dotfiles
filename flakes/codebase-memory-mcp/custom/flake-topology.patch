diff --git a/src/pipeline/pipeline_internal.h b/src/pipeline/pipeline_internal.h
index 1eb1084..f0764aa 100644
--- a/src/pipeline/pipeline_internal.h
+++ b/src/pipeline/pipeline_internal.h
@@ -470,6 +470,14 @@ int cbm_pipeline_pass_tests(cbm_pipeline_ctx_t *ctx, const cbm_file_info_t *file
 
 int cbm_pipeline_pass_githistory(cbm_pipeline_ctx_t *ctx);
 
+/* Pre-dump pass: Nix flake topology from flake.lock — one Flake node per lock
+ * node plus DEPENDS_ON / FOLLOWS / MOUNTS edges. No-op when no flake.lock. */
+int cbm_pipeline_pass_flakelock(cbm_pipeline_ctx_t *ctx);
+
