Extract Nix symbols (bindings + named lambdas) into the knowledge graph.

Upstream wires the Nix language spec (function/variable node types) but its
generic name-resolution can't name Nix's shapes, so .nix files yielded only a
file-level Module node and zero symbols. This teaches the definition extractor
about Nix's AST:

  * resolve_nix_func_name(): a lambda (function_expression) is anonymous; name it
    from the attrpath of the binding it is the value of (`mkFoo = x: ...` -> mkFoo).
    Wired into resolve_func_name_scripting().
  * walk_defs() now descends into Nix function bodies so named lambdas nested in a
    file-level `{ ... }:` module-args lambda (the dendritic
    `flake.modules.darwin.<name> = { ... }: { ... }` pattern) are captured.
  * walk_nix_bindings(): bindings (`attrpath = expr;`) nest arbitrarily deep inside
    attrsets/let-expressions, so the top-level-only variable walk never reached
    them. Walk the whole tree and emit a Variable per binding (named by attrpath),
    skipping function-valued bindings (handled as Functions above) to avoid dupes.
  * lang_specs.c: the Nix module node type was the nonexistent "source_expression";
    the grammar's root is "source_code".

Result on a Nix-heavy repo: 0 -> ~700 symbols (option paths like
options.kriswill.<feature>.enable as Variables, module defs as Functions).

diff --git a/internal/cbm/extract_defs.c b/internal/cbm/extract_defs.c
index 913268d..07a0801 100644
--- a/internal/cbm/extract_defs.c
+++ b/internal/cbm/extract_defs.c
@@ -294,8 +294,25 @@ static TSNode resolve_vimscript_func_name(TSNode node) {
     return null_node;
 }
 
+// Nix: a lambda (function_expression) is anonymous. Name it from the attrpath of
+// the binding it is the value of (`mkFoo = x: ...` -> "mkFoo"). Only a lambda whose
+// direct parent is the binding is named, so curried inner lambdas are not counted
+// twice; anonymous lambdas (a file-level `{ pkgs, ... }: ...`, or a `map (x: ...)`
+// argument) have no binding parent and stay unnamed (and are thus skipped).
+static TSNode resolve_nix_func_name(TSNode node) {
+    TSNode parent = ts_node_parent(node);
+    if (!ts_node_is_null(parent) && strcmp(ts_node_type(parent), "binding") == 0) {
+        return ts_node_child_by_field_name(parent, TS_FIELD("attrpath"));
+    }
+    TSNode null_node = {0};
+    return null_node;
+}
+
 // Resolve function name for scripting/niche languages (Lua, OCaml, SQL, Zig, VimScript, Julia).
 static TSNode resolve_func_name_scripting(TSNode node, CBMLanguage lang, const char *kind) {
+    if (lang == CBM_LANG_NIX && strcmp(kind, "function_expression") == 0) {
+        return resolve_nix_func_name(node);
+    }
     if (lang == CBM_LANG_LUA && strcmp(kind, "function_definition") == 0) {
         return resolve_lua_func_name(node);
     }
@@ -4636,11 +4653,52 @@ static void extract_yaml_toplevel_keys(CBMExtractCtx *ctx, TSNode root) {
     }
 }
 
+// Nix: bindings (`attrpath = expr;`) carry their name in the `attrpath` field and
+// nest arbitrarily deep inside attrsets / let-expressions, so the top-level-only
+// extract_variables walk never reaches them. Walk the whole subtree and emit a
+// Variable for each binding, skipping bindings whose value is a function_expression
+// (those become Functions via walk_defs / resolve_nix_func_name) so a function is
+// not counted twice. `inherit` statements are left for a future pass.
+static void walk_nix_bindings(CBMExtractCtx *ctx, TSNode root) {
+    CBMArena *a = ctx->arena;
+    TSNodeStack stack;
+    ts_nstack_init(&stack, ctx->arena, CBM_SZ_256);
+    ts_nstack_push(&stack, ctx->arena, root);
+
+    while (stack.count > 0) {
+        TSNode node = ts_nstack_pop(&stack);
+        if (strcmp(ts_node_type(node), "binding") == 0) {
+            TSNode val = ts_node_child_by_field_name(node, TS_FIELD("expression"));
+            bool is_func =
+                !ts_node_is_null(val) && strcmp(ts_node_type(val), "function_expression") == 0;
+            if (!is_func) {
+                TSNode attrpath = ts_node_child_by_field_name(node, TS_FIELD("attrpath"));
+                if (!ts_node_is_null(attrpath)) {
+                    push_var_def(ctx, cbm_node_text(a, attrpath, ctx->source), node);
+                }
+            }
+        }
+        uint32_t count = ts_node_child_count(node);
+        for (int i = (int)count - SKIP_CHAR; i >= 0; i--) {
+            TSNode child = ts_node_child(node, (uint32_t)i);
+            if (!ts_node_is_null(child)) {
+                ts_nstack_push(&stack, ctx->arena, child);
+            }
+        }
+    }
+}
+
 static void extract_variables(CBMExtractCtx *ctx, TSNode root, const CBMLangSpec *spec) {
     if (!spec->variable_node_types || !spec->variable_node_types[0]) {
         return;
     }
 
+    // Nix: bindings nest inside attrsets/let-expressions; walk the whole tree.
+    if (ctx->language == CBM_LANG_NIX) {
+        walk_nix_bindings(ctx, root);
+        return;
+    }
+
     // Helm values.yaml: only top-level keys, not the per-leaf flood.
     if (ctx->language == CBM_LANG_YAML && is_helm_values_file(ctx->rel_path)) {
         extract_yaml_toplevel_keys(ctx, root);
@@ -5428,10 +5486,14 @@ static void walk_defs(CBMExtractCtx *ctx, TSNode root, const CBMLangSpec *spec,
                 // Ada subprograms nest (a procedure body's declarative part can
                 // contain inner subprogram bodies); descend so the nested defs
                 // are captured and same-file calls to them resolve to a CALLS edge.
+                // Nix lambdas nest: a file-level `{ ... }:` module-args lambda wraps a
+                // body whose bindings are themselves lambdas (e.g. dendritic
+                // `flake.modules.darwin.<name> = { ... }: { ... }`). Descend so those
+                // named inner lambdas are captured instead of stopping at the outer one.
                 bool descend_into_func =
                     (ctx->language == CBM_LANG_WOLFRAM || ctx->language == CBM_LANG_TYPESCRIPT ||
                      ctx->language == CBM_LANG_JAVASCRIPT || ctx->language == CBM_LANG_TSX ||
-                     ctx->language == CBM_LANG_ADA);
+                     ctx->language == CBM_LANG_ADA || ctx->language == CBM_LANG_NIX);
                 if (!descend_into_func) {
                     continue;
                 }
