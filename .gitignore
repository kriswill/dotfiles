.direnv
pkgs/result
**/.DS_Store
.obsidian
**/result
# Ignore local Claude state (settings.local.json, worktrees). Skills live in
# .agents/skills (harness-neutral); .claude/skills is a tracked symlink to them
# so Claude Code still discovers them.
.claude/*
!.claude/skills
.todos/

# Compiled Neovim spellfile (regenerated from the tracked .add)
config/nvim/spell/*.spl

# Sidecar worktree state files
.sidecar/
.sidecar-agent
.sidecar-task
.sidecar-pr
.sidecar-start.sh
.sidecar-base
.td-root
