# Kris' ssh config — stow-managed (home/ssh/.ssh/config), symlinked to
# ~/.ssh/config by modules/{darwin,nixos}/dotfiles-stow.nix on both OSes.
# Host-specific entries are pulled in from ~/.ssh/config.d/*
# (e.g. the sops-managed private hosts, modules/*/ssh-private-hosts.nix).
Include config.d/*

# 1Password ssh agent — socket path differs per OS.
Match exec "uname | grep -q Darwin"
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
Match exec "uname | grep -q Linux"
  IdentityAgent "~/.1password/agent.sock"

Host *
  ForwardAgent yes
