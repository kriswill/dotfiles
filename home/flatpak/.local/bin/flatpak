#!/usr/bin/env bash
# Default flatpak to the per-user installation (~/.local/share/flatpak).
#
# flatpak's CLI hardcodes --system as the default and offers no config to change
# it, so this wrapper (earlier on PATH than /run/current-system/sw/bin) injects
# --user for the scope-aware subcommands. It respects an explicit scope if you
# pass one (--user/-u/--system/--installation), and passes non-scoped subcommands
# (run, ps, help, --version, build*, …) through untouched. Managed in dotfiles
# (home/flatpak); see modules/hosts/nebula/flatpak-repo-user.nix for the rest of
# the user-only flatpak setup.
set -euo pipefail

real=/run/current-system/sw/bin/flatpak

# If the caller already chose a scope, don't second-guess it.
for arg in "$@"; do
  case "$arg" in
    -u | --user | --system | --installation | --installation=*)
      exec "$real" "$@"
      ;;
  esac
done

# First non-option argument is the subcommand.
cmd=""
for arg in "$@"; do
  case "$arg" in
    -*) ;;
    *)
      cmd="$arg"
      break
      ;;
  esac
done

case "$cmd" in
  install | uninstall | update | list | info | search | remotes | remote-add \
    | remote-modify | remote-delete | remote-ls | remote-info | mask | pin \
    | override | make-current | repair | config | create-usb)
    # Insert --user immediately after the subcommand.
    out=()
    inserted=0
    for arg in "$@"; do
      out+=("$arg")
      if [ "$inserted" -eq 0 ] && [ "$arg" = "$cmd" ]; then
        out+=(--user)
        inserted=1
      fi
    done
    exec "$real" "${out[@]}"
    ;;
  *)
    exec "$real" "$@"
    ;;
esac
