# Sign commits/tags with the SSH key held in 1Password. The agent socket is
# exposed per-OS (NixOS: `programs._1password-gui`; macOS: the 1Password.app
# bundle). `op-ssh-sign` lives at a different absolute path on each OS, so the
# program is selected below by home-dir prefix rather than hardcoded — this file
# is shared across machines, so a single path would break signing on the other.
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
# Every repo lives under the home dir, whose prefix differs by OS (/home on
# Linux, /Users on macOS), so git's gitdir condition is a reliable OS
# discriminator. gitdir resolves symlinks, so nebula's /etc/nixos -> /home/k/...
# rebuild path also matches the Linux branch. Relative include paths resolve
# next to this file (~/.config/git/), where stow links the .inc siblings.
[includeIf "gitdir:/home/"]
	path = signing-linux.inc
[includeIf "gitdir:/Users/"]
	path = signing-macos.inc
[diff]
	tool = difftastic
[difftool]
	prompt = false
[difftool "difftastic"]
	cmd = difft "$LOCAL" "$REMOTE"
# diffnav (a delta-based TUI with a GitHub-style file tree) pages `git diff` and
# `git show`. `git difftool` still launches difftastic (above) for per-file
# dir-diffs, since diffnav only renders a unified diff piped on stdin.
[pager]
	diff = diffnav
	show = diffnav
	difftool = true
# Styling for delta, which diffnav drives. Kanagawa palette, mirrored from the
# main branch's modules/home-manager/diffnav.nix.
[delta]
	syntax-theme = ansi
	dark = true
	tabs = 2
	file-style = omit
	file-decoration-style = none
	line-numbers = true
	line-numbers-left-format = "{nm:>4} "
	line-numbers-right-format = "│ {np:>4} "
	line-numbers-left-style = "#54546D dim"
	line-numbers-right-style = "#2A2A37 dim"
	line-numbers-zero-style = "#54546D dim"
	line-numbers-plus-style = "#54546D dim"
	line-numbers-minus-style = "#54546D dim"
	plus-style = "syntax #222B26"
	plus-emph-style = "syntax #2B3328"
	minus-style = "syntax #2B2024"
	minus-emph-style = "syntax #3A242B"
	hunk-header-style = "#727169"
	hunk-header-file-style = "#727169 dim"
	hunk-header-line-number-style = "#223249"
	hunk-header-decoration-style = "#2A2A37 ol ul"
	wrap-left-symbol = " "
	wrap-right-symbol = " "
	wrap-right-prefix-symbol = " "
[commit]
	gpgsign = true
[tag]
	gpgsign = true
# Use the GitHub CLI as the credential helper for HTTPS pushes/fetches. The
# empty `helper =` first resets any inherited helpers; `!gh auth git-credential`
# resolves `gh` from PATH (the stable /run/current-system/sw/bin) rather than an
# absolute /nix/store path, so it survives gh upgrades. `gh auth setup-git`
# would otherwise write this (with a store path) into ~/.gitconfig, which shadows
# this file — keep it here so it stays tracked and XDG remains authoritative.
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
