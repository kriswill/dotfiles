# Kris' git config — stow-managed (home/git/.config/git/config), symlinked to
# ~/.config/git/config by the dotfiles-stow module of each OS
# (modules/darwin/dotfiles-stow.nix, modules/nixos/dotfiles-stow.nix). Edit
# live; no rebuild needed. Ported from the old home-manager programs.git module.
#
# Helper commands are referenced by bare name (gh, git-lfs, rg, jq, difft)
# instead of /nix/store paths: this is a static file (not regenerated on
# rebuild), so a pinned store path would go stale on the next package bump.
# All are on PATH via the git/user-packages modules of each OS.
#
# [pager] points at diffnav. [credential] comes from the old programs.gh;
# [filter "lfs"] from programs.git.lfs.

[alias]
	amend = "commit --amend -m"
	br = "branch"
	ca = "commit -am"
	cm = "commit -m"
	co = "checkout"
	dc = "diff --cached"
	fixup = "!f(){ git reset --soft HEAD~${1} && git commit --amend -C HEAD; };f"
	ll = "!git log --pretty=format:'%C(yellow)%h%Cred%d %Creset%s%Cblue [%cn]%Creset %G?' --color=always --decorate --numstat \"$@\" | sed 's/ G$/ 🔒/;s/ N$/ ➖/;s/ [UE]$/ 🔑/;s/ [BXYR]$/ ⚠️/' | less -RFX"
	loc = "!f(){ git ls-files | rg \"\\.${1}\" | xargs wc -l; };f"
	ls = "!git log --pretty=format:'%C(yellow)%h%Cred%d %Creset%s%Cblue [%cn]%Creset %G?' --color=always --decorate \"$@\" | sed 's/ G$/ 🔒/;s/ N$/ ➖/;s/ [UE]$/ 🔑/;s/ [BXYR]$/ ⚠️/' | less -RFX"
	st = "status"

[commit]
	gpgsign = true

[core]
	editor = "nvim"

[credential "https://gist.github.com"]
	helper = ""
	helper = "!gh auth git-credential"

[credential "https://github.com"]
	helper = ""
	helper = "!gh auth git-credential"

