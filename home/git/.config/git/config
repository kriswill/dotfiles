# Styling for delta, which diffnav drives. Kanagawa palette (kept in sync by
# hand with lib/kanagawa.nix).
[delta]
	syntax-theme = "ansi"
	dark = true
	tabs = 2
	file-style = "omit"
	file-decoration-style = "none"
	line-numbers = true
	line-numbers-left-format = "{nm:>4} "
	line-numbers-right-format = "│ {np:>4} "
	line-numbers-left-style = "#54546D dim"
	line-numbers-right-style = "#2A2A37 dim"
	line-numbers-zero-style = "#54546D dim"
	line-numbers-plus-style = "#54546D dim"
	line-numbers-minus-style = "#54546D dim"
	plus-style = "syntax #222B26"
	plus-emph-style = "syntax #2B3328"
	minus-style = "syntax #2B2024"
	minus-emph-style = "syntax #3A242B"
	hunk-header-style = "#727169"
	hunk-header-file-style = "#727169 dim"
	hunk-header-line-number-style = "#223249"
	hunk-header-decoration-style = "#2A2A37 ol ul"
	wrap-left-symbol = " "
	wrap-right-symbol = " "
	wrap-right-prefix-symbol = " "

# `git difftool` launches difftastic for per-file dir-diffs; diffnav (below)
# only renders a unified diff piped on stdin.
[diff]
	tool = "difftastic"

[difftool]
	prompt = false

[difftool "difftastic"]
	cmd = "difft \"$LOCAL\" \"$REMOTE\""

[filter "lfs"]
	clean = "git-lfs clean -- %f"
	process = "git-lfs filter-process"
	required = true
	smudge = "git-lfs smudge -- %f"

[filter "normalize-podman-settings"]
	clean = "jq 'del(.\"window.bounds\", .\"titleBar.searchBar\".remindAt, .\"statusbarProviders.showProviders\".remindAt)' "
	smudge = "cat"

[gpg]
	format = "ssh"

[gpg "ssh"]
	allowedSignersFile = "~/.config/git/allowed_signers"

# op-ssh-sign lives at a different absolute path per OS (macOS: the 1Password.app
# bundle; NixOS: the system-profile path). This config is shared across machines,
# so select the program by home-dir prefix rather than hardcoding one — every
# repo lives under $HOME, whose prefix differs by OS (/Users vs /home), and
# gitdir resolves symlinks so a symlinked path still matches (nebula's
# /etc/nixos -> /home/k/... rebuild path also matches the Linux branch).
# Relative include paths resolve next to this file (~/.config/git/), where stow
# links the siblings.
[includeIf "gitdir:/Users/"]
	path = "signing-macos.inc"
[includeIf "gitdir:/home/"]
	path = "signing-linux.inc"

[init]
	defaultBranch = "main"

[merge]
	conflictStyle = "zdiff3"
	tool = "vim_mergetool"

[mergetool "vim_mergetool"]
	cmd = "nvim -f -c \"MergetoolStart\" \"$MERGED\" \"$BASE\" \"$LOCAL\" \"$REMOTE\""
	prompt = false

[pager]
	diff = "diffnav"
	show = "diffnav"
	difftool = true

[pull]
	rebase = false

[push]
	autoSetupRemote = true

[tag]
	gpgsign = true

[url "https://github.com/"]
	insteadOf = "gh:"

[url "https://gitlab.com/"]
	insteadOf = "gl:"

[url "ssh://git@github.com"]
	pushInsteadOf = "gh:"

[url "ssh://git@gitlab.com"]
